{
  "name": "react-strapi-monorepo-template",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/xmasny/react-strapi-monorepo-template.git"
  },
  "scripts": {
    "dev": "concurrently -k -n \"STRAPI,WEB\" -c \"green,blue\" \"yarn dev:strapi\" \"yarn dev:web\"",
    "dev:all": "concurrently -k -n \"STRAPI,WEB,STORYBOOK\" -c \"green,blue,magenta\" \"yarn dev:strapi\" \"yarn dev:web\" \"yarn dev:storybook\"",
    "dev:web": "yarn workspace @react-strapi-monorepo-template/web dev",
    "dev:strapi": "yarn workspace @react-strapi-monorepo-template/strapi dev",
    "dev:storybook": "yarn workspace @react-strapi-monorepo-template/storybook storybook",
    "build": "yarn build:web && yarn build:strapi && yarn build:storybook",
    "build:web": "yarn workspace @react-strapi-monorepo-template/web build",
    "build:strapi": "yarn workspace @react-strapi-monorepo-template/strapi build",
    "build:storybook": "yarn workspace @react-strapi-monorepo-template/storybook build-storybook",
    "start:web": "yarn workspace @react-strapi-monorepo-template/web preview",
    "start:strapi": "yarn workspace @react-strapi-monorepo-template/strapi start",
    "test": "yarn test:web && yarn test:storybook",
    "test:web": "yarn workspace @react-strapi-monorepo-template/web test:ct",
    "test:web:debug": "yarn workspace @react-strapi-monorepo-template/web test:ct:debug",
    "test:web:ui": "yarn workspace @react-strapi-monorepo-template/web test:ct:ui",
    "test:storybook": "yarn workspace @react-strapi-monorepo-template/storybook test:storybook",
    "test:storybook:ci": "yarn workspace @react-strapi-monorepo-template/storybook test:storybook:ci",
    "graphql:codegen": "yarn workspace @react-strapi-monorepo-template/graphql codegen",
    "lint:web": "yarn workspace @react-strapi-monorepo-template/web lint",
    "prepare": "husky",
    "typecheck": "yarn typecheck:web && yarn typecheck:storybook",
    "typecheck:storybook": "yarn workspace @react-strapi-monorepo-template/storybook typecheck",
    "typecheck:web": "yarn workspace @react-strapi-monorepo-template/web typecheck"
  },
  "lint-staged": {
    "**/package.json": [
      "sort-package-json",
      "git add"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "sort-package-json": "^3.6.1",
    "tsc": "^2.0.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.14.1",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ]
  }
}
